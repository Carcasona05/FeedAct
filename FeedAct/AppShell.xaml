<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FeedAct.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FeedAct.Views"
    Title="FeedAct"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <ShellContent
        ContentTemplate="{DataTemplate views:MainPage}"
        Route="MainPage" />
    
    <ShellContent
        ContentTemplate="{DataTemplate views:AddPostPage}"
        Route="AddPostPage" />
    
    <ShellContent
        ContentTemplate="{DataTemplate views:PostDetailPage}"
        Route="PostDetailPage" />
        
</Shell>
