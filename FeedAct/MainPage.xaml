<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FeedAct.MainPage"
             Title="Social Feed"
             BackgroundColor="#0F0F0F">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Grid ColumnDefinitions="*" 
              Padding="20,16"
              BackgroundColor="#0F0F0F">
            <VerticalStackLayout VerticalOptions="Center">
                <Label Text="Activity Feed"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="White" />
                <Label Text="Share something with the world"
                       FontSize="13"
                       TextColor="#AAAAAA"
                       Margin="0,-4,0,0" />
            </VerticalStackLayout>
        </Grid>

        <!-- Feed -->
        <CollectionView x:Name="FeedCollection"
                        Grid.Row="1"
                        SelectionMode="None"
                        Margin="16,12">

            <CollectionView.EmptyView>
                <StackLayout Padding="40"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">
                    <Label Text="📝"
                           FontSize="64"
                           HorizontalOptions="Center"
                           Opacity="0.2" />
                    <Label Text="No posts yet"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#BBBBBB"
                           HorizontalOptions="Center"
                           Margin="0,16,0,8" />
                    <Label Text="Tap + to create your first post"
                           FontSize="15"
                           TextColor="#777777"
                           HorizontalOptions="Center" />
                </StackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="0"
                            BackgroundColor="#1A1A1A"
                            StrokeShape="RoundRectangle 20"
                            Margin="0,0,0,14"
                            Padding="0">

                        <Border.Shadow>
                            <Shadow Brush="#000000"
                                    Opacity="0.4"
                                    Radius="12"
                                    Offset="0,6" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="0">

                            <!-- Post Header -->
                            <Grid ColumnDefinitions="Auto,*,Auto" 
                                  Padding="16,16,16,12"
                                  ColumnSpacing="12">

                                <!-- Avatar -->
                                <Border WidthRequest="44"
                                        HeightRequest="44"
                                        BackgroundColor="#FF0050"
                                        StrokeShape="RoundRectangle 22">
                                    <Label Text="{Binding Author, Converter={StaticResource StringToInitials}}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <!-- Author Info -->
                                <VerticalStackLayout Grid.Column="1" 
                                                     Spacing="2"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Author}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                    <Label Text="{Binding TimeAgo}"
                                           FontSize="13"
                                           TextColor="#888888" />
                                </VerticalStackLayout>

                                <!-- Visibility Icon -->
                                <Label Grid.Column="2"
                                       Text="{Binding VisibilityIcon}"
                                       FontSize="18"
                                       VerticalOptions="Center"
                                       TextColor="#AAAAAA" />
                            </Grid>

                            <!-- Post Content -->
                            <Label Text="{Binding Content}"
                                   FontSize="15"
                                   LineHeight="1.4"
                                   TextColor="#DDDDDD"
                                   Padding="16,0,16,12"
                                   IsVisible="{Binding Content, Converter={StaticResource StringIsNotNullOrEmpty}}" />

                            <!-- Post Image -->
                            <Border StrokeThickness="0"
                                    StrokeShape="RoundRectangle 0"
                                    IsVisible="{Binding HasImage}">
                                <Image Source="{Binding ImagePath}"
                                       HeightRequest="300"
                                       Aspect="AspectFill" />
                            </Border>

                            <!-- Post Footer -->
                            <Grid Padding="16,12,16,14"
                                  BackgroundColor="#141414">

                                <Border StrokeThickness="0"
                                        BackgroundColor="#FF0050"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="16,10"
                                        HorizontalOptions="Start">

                                    <Label Text=" View Comments"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="White">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnCommentsClicked" />
                                        </Label.GestureRecognizers>
                                    </Label>

                                </Border>
                            </Grid>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Floating Action Button -->
        <Border Grid.Row="2"
                WidthRequest="64"
                HeightRequest="64"
                BackgroundColor="#FF0050"
                StrokeShape="RoundRectangle 32"
                HorizontalOptions="Center"
                Margin="0,0,0,20">

            <Border.Shadow>
                <Shadow Brush="#FF0050"
                        Opacity="0.6"
                        Radius="16"
                        Offset="0,6" />
            </Border.Shadow>

            <Button Text="+"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="36"
                    Clicked="OnAddPostClicked" />

        </Border>

    </Grid>
</ContentPage>